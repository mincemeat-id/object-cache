{
    "name": "mincemeat/object-cache",
    "description": "Development tooling for Mincemeat Object Cache (object cache runtime is a standalone drop-in).",
    "type": "wordpress-plugin",
    "license": "GPL-3.0-or-later",
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "yoast/phpunit-polyfills": "^4.0",
        "wp-coding-standards/wpcs": "^3.3",
        "phpcompatibility/php-compatibility": "^9.3",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "phpstan/phpstan": "^2.2.5"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "Mincemeat\\ObjectCache\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mincemeat\\ObjectCache\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "build": "php tools/build-dropin.php",
        "test": "phpunit",
        "test:setup": "bash tools/install-wp-tests.sh",
        "test:unit": "phpunit --group unit",
        "test:contract": "phpunit --group contract",
        "test:integration": "phpunit --group integration",
        "test:smoke": "php tools/run-smoke-tests.php",
        "test:coverage": "php tools/verify-coverage.php",
        "lint": "phpcs",
        "compat": "phpcs --standard=PHPCompatibility",
        "stan": "phpstan analyse"
    }
}